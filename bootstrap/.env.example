# Engineering OS Bootstrapper — Example Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # Fill in the values below
#   python main.py
# ─────────────────────────────────────────────────────────────────────────────

# ── Atlassian Authentication ──────────────────────────────────────────────────
# Your Atlassian account email address
ATLASSIAN_EMAIL=your-email@example.com

# Atlassian API token (NOT your account password)
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=your-api-token-here

# Base URL of your Atlassian Cloud instance (no trailing slash)
ATLASSIAN_BASE_URL=https://your-org.atlassian.net

# ── Confluence ────────────────────────────────────────────────────────────────
# Cloud ID from your Atlassian admin panel
# Find at: https://your-org.atlassian.net/wiki/rest/api/settings/systemInfo
CONFLUENCE_CLOUD_ID=your-cloud-id-here

# Numeric ID of the root Confluence space
# Find by: GET /wiki/rest/api/space?spaceKey=YOUR_KEY
CONFLUENCE_ROOT_SPACE_ID=65841

# Space key (short identifier shown in Confluence URLs)
CONFLUENCE_ROOT_SPACE_KEY=TWC

# ── Jira ─────────────────────────────────────────────────────────────────────
# Default Jira project key (e.g., LAZYA for lazyahh project)
JIRA_PROJECT_KEY=LAZYA

# Atlassian account ID of the default issue assignee
# Find at: GET /rest/api/3/myself
JIRA_DEFAULT_ASSIGNEE=your-account-id-here

# ── Bootstrap Behaviour ───────────────────────────────────────────────────────
# Set to true to simulate without making any changes (overridden by --dry-run flag)
DRY_RUN=false

# Set to true to skip pages/issues that already exist (overridden by --resume flag)
RESUME=true

# Maximum number of retry attempts on transient failures (429, 5xx)
MAX_RETRIES=5

# Exponential backoff base in seconds: delay = base^attempt
RETRY_BACKOFF_BASE=2.0

# HTTP request timeout in seconds
REQUEST_TIMEOUT=30

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
