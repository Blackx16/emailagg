# ─── App ──────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── Internal URLs (Docker networking) ─────────────────────────
BACKEND_INTERNAL_URL=http://backend:8000

# ─── Frontend (Next.js build-time vars) ──────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────
POSTGRES_DB=emailagg
POSTGRES_USER=emailagg
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://emailagg:change-me-strong-password@db:5432/emailagg

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# ─── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:change-me-redis-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-redis-password@redis:6379/2

# ─── Token Encryption (Fernet) ────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-fernet-key

# ─── Microsoft OAuth ──────────────────────────────────────────
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://yourdomain.com/api/v1/auth/microsoft/callback

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/v1/auth/google/callback

# ─── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot/webhook

# ─── Flower (Celery Monitor) ──────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-flower-password

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Mail Sync ────────────────────────────────────────────────
# How often to poll inboxes (in seconds) when webhooks aren't available
SYNC_POLL_INTERVAL=300
# Max emails fetched per sync cycle per account
SYNC_BATCH_SIZE=50

# ─── SMTP Forwarding ──────────────────────────────────────────
SMTP_HOST=smtp.mailcow.yourdomain.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=change-me
SMTP_FROM_ADDRESS=noreply@yourdomain.com
